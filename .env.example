# Vorlage. Bei Bedarf als .env kopieren ODER die Werte direkt in der
# systemd-Unit (Environment=) bzw. per EnvironmentFile setzen.
# Die .env selbst wird NICHT eingecheckt (siehe .gitignore).

# Datenverzeichnis: hier liegen SQLite-Datenbank und Logs. Muss beschreibbar sein.
VK_DATA_DIR=/opt/vereinskasse-daten

# Erst-Administrator-PIN beim allerersten Start (nur wirksam, solange noch kein
# Benutzer existiert). Leer lassen -> es wird einmalig eine zufällige 6-stellige
# PIN erzeugt und ins Log geschrieben (journalctl -u vereinskasse-backend | grep Start-PIN).
VK_INITIAL_ADMIN_PIN=

# Netzwerk-Bindung des Backends (lokal, hinter dem Kiosk).
VK_HOST=127.0.0.1
VK_PORT=8000

# PBKDF2-Iterationen für PIN-Hashes. In Produktion den Standard belassen;
# nur für automatisierte Tests klein setzen.
# VK_PBKDF2_ITERATIONS=200000
